# =============================================================================
# SHATTERED Environment Configuration
# =============================================================================
# Copy to .env and customize for your deployment.
# All variables have sensible defaults in docker-compose.yml.
# =============================================================================

# --- Database ---
POSTGRES_USER=arkham
POSTGRES_PASSWORD=arkhampass
POSTGRES_DB=arkhamdb

# --- Application ---
APP_PORT=8100

# --- Authentication (REQUIRED for production) ---
# Generate with: openssl rand -hex 32
AUTH_SECRET_KEY=CHANGE-ME-IN-PRODUCTION
JWT_LIFETIME_SECONDS=3600

# --- LLM Configuration (optional — works without it) ---
# Provider endpoint (OpenRouter, LM Studio, Ollama, etc.)
LLM_ENDPOINT=
LLM_API_KEY=
# Alternative: LM Studio on host machine
LM_STUDIO_URL=

# --- VLM for OCR (optional) ---
VLM_ENDPOINT=

# --- Embedding Model (optional — enables semantic search) ---
# Recommended: BAAI/bge-m3 (1024 dims, high quality)
# Lightweight: all-MiniLM-L6-v2 (384 dims, fast)
# WARNING: Changing models requires rebuilding vector collections
EMBED_MODEL=all-MiniLM-L6-v2
